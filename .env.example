# Copy to .env and fill in your values.  .env is gitignored (never commit real keys).
#
# The planner is chosen by AGENT_PLANNER. The default ("rule") is deterministic
# and needs no key. Set it to "llm" to use a real LLM (NVIDIA NIM).

# rule | llm   (default: rule)
AGENT_PLANNER=llm

# ---- LLM planner config (only used when AGENT_PLANNER=llm) -------------------
# NVIDIA NIM is OpenAI-compatible; LLMPlanner drives it with the `openai` SDK.
# Requires: pip install openai
LLM_PROVIDER=nvidia
LLM_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional override (defaults to NVIDIA's public endpoint):
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
